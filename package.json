{
  "name": "promptstats",
  "version": "2.0.0",
  "description": "Privacy-first prompt analytics browser extension",
  "scripts": {
    "test":        "jest --coverage",
    "test:watch":  "jest --watch",
    "e2e":         "playwright test",
    "mock-server": "npx http-server e2e/mock-page -p 3999 --silent"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "http-server":      "^14.1.1",
    "jest":             "^29.7.0",
    "jsdom":            "^24.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/content/engines/*.js"
    ]
  }
}
